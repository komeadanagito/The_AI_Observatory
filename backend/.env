# ============================================
# AI 玄学洞见平台 - 后端配置模板
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/ai_observatory
REDIS_URL=redis://localhost:6379/0

# ============================================
# AI 模型配置 (OpenAI 兼容格式)
# ============================================
# 支持: OpenAI / DeepSeek / 智谱GLM / 本地Ollama 等

# --- OpenAI 官方 ---
# MODEL_API_BASE=https://api.openai.com/v1
# MODEL_API_KEY=sk-your-api-key-here
# MODEL_NAME=gpt-4

# --- DeepSeek ---
# MODEL_API_BASE=https://api.deepseek.com/v1
# MODEL_API_KEY=sk-your-deepseek-key
# MODEL_NAME=deepseek-chat

# --- 本地 Ollama ---
MODEL_API_BASE=http://localhost:11434/v1
MODEL_API_KEY=ollama
MODEL_NAME=qwen3:8b

# --- 智谱 GLM ---
# MODEL_API_BASE=https://open.bigmodel.cn/api/paas/v4
# MODEL_API_KEY=your-glm-key
# MODEL_NAME=glm-4

# ============================================
# JWT 认证配置
# ============================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# 数据加密配置
# ============================================
# 用于加密用户敏感数据 (生日、出生时间等)
# 必须是 32 字节的 base64 编码字符串
ENCRYPTION_KEY=your-32-byte-encryption-key-base64

# ============================================
# 邮件服务配置 (密码重置)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=AI玄学洞见平台

# ============================================
# 应用配置
# ============================================
APP_NAME=AI玄学洞见平台
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# CORS 配置 (逗号分隔的允许来源)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
